{
  "name": "n8n-nextcloud-integration",
  "version": "1.0.0",
  "description": "AI Agent integration for n8n Nextcloud Tasks and Calendar",
  "status": "available",
  "endpoints": {
    "tasks": {
      "url": "http://localhost:5678/webhook/nextcloud-tasks",
      "method": "POST",
      "actions": ["fetch", "create", "update", "delete"],
      "description": "Manage Nextcloud Tasks"
    },
    "calendar": {
      "url": "http://localhost:5678/webhook/nextcloud-calendar",
      "method": "POST",
      "actions": ["fetch", "create", "delete"],
      "description": "Manage Nextcloud Calendar Events"
    }
  },
  "authentication": {
    "type": "http_basic",
    "description": "Nextcloud username and app password"
  },
  "capabilities": {
    "tasks": {
      "create": {
        "description": "Create a new task",
        "required_fields": ["title"],
        "optional_fields": ["description", "due", "startDate", "status", "priority", "percentComplete", "categories", "parentTaskUid", "duration", "recurrence", "location"]
      },
      "read": {
        "description": "List all tasks",
        "required_fields": [],
        "returns": "Array of task files with filenames"
      },
      "update": {
        "description": "Update an existing task",
        "required_fields": ["taskUid"],
        "optional_fields": ["title", "description", "due", "status", "priority", "percentComplete", "categories"]
      },
      "delete": {
        "description": "Delete a task",
        "required_fields": ["taskUid"]
      }
    },
    "calendar": {
      "create": {
        "description": "Create a new calendar event",
        "required_fields": ["title"],
        "optional_fields": ["start", "end", "allDay", "location", "description", "status", "categories", "recurrence"]
      },
      "read": {
        "description": "List all calendar events",
        "required_fields": [],
        "returns": "Array of event files with filenames"
      },
      "delete": {
        "description": "Delete a calendar event",
        "required_fields": ["eventUid"]
      }
    }
  },
  "examples": {
    "create_task": {
      "action": "create",
      "title": "Buy groceries",
      "priority": 3,
      "due": "2025-01-20T18:00:00"
    },
    "create_event": {
      "action": "create",
      "title": "Team Meeting",
      "start": "2025-01-20T09:00:00",
      "end": "2025-01-20T10:00:00"
    }
  },
  "documentation": {
    "openapi": "./openapi.yaml",
    "instructions": "./INSTRUCTIONS.md",
    "github": "https://github.com/ahmed-rezk-dev/n8n-workflows"
  }
}
