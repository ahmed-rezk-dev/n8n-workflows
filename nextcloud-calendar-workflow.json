{
  "name": "Nextcloud - Calendar Manager",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "nextcloud-calendar",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "calendar-manager"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "action", "name": "action", "value": "={{ $('Webhook').first().json.body.action }}", "type": "string" },
            { "id": "body", "name": "body", "value": "={{ $('Webhook').first().json.body }}", "type": "object" }
          ]
        }
      },
      "id": "set-config",
      "name": "Set Config",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [470, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" }, "conditions": [{ "leftValue": "={{ $json.action }}", "rightValue": "fetch", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "Fetch" },
            { "conditions": { "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" }, "conditions": [{ "leftValue": "={{ $json.action }}", "rightValue": "create", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "Create" },
            { "conditions": { "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" }, "conditions": [{ "leftValue": "={{ $json.action }}", "rightValue": "delete", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "Delete" }
          ]
        },
        "options": { "fallbackOutput": "extra" }
      },
      "id": "switch-action",
      "name": "Switch Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [690, 300]
    },
    {
      "parameters": {
        "jsCode": "const nextcloudUrl = 'https://cloud.tal.ahmed-rezk.com';\nconst nextcloudUser = 'admin';\nconst calendarName = 'personal';\nconst auth = Buffer.from('admin:4EMsB-kQLNn-YdnCC-9Dd6Z-GA9jj').toString('base64');\n\ntry {\n  const response = await this.helpers.httpRequest({\n    method: 'PROPFIND',\n    url: `${nextcloudUrl}/remote.php/dav/calendars/${nextcloudUser}/${calendarName}/`,\n    headers: {\n      'Authorization': `Basic ${auth}`,\n      'Content-Type': 'application/xml',\n      'Depth': '1'\n    },\n    body: '<?xml version=\"1.0\"?><d:propfind xmlns:d=\"DAV:\"><d:prop><d:getetag/></d:prop></d:propfind>',\n    returnFullResponse: true\n  });\n  \n  const xml = response.body || response.data || '';\n  const files = [];\n  const hrefMatches = xml.match(/<d:href>([^<]*\\.ics)<\\/d:href>/gi) || [];\n  for (const m of hrefMatches) {\n    const href = m.match(/<d:href>([^<]*)<\\/d:href>/i)[1];\n    const filename = href.split('/').pop().replace('.ics', '');\n    files.push({ filename, href });\n  }\n  return [{ json: { success: true, files, count: files.length } }];\n} catch (error) {\n  return [{ json: { success: false, error: error.message } }];\n}"
      },
      "id": "fetch-events",
      "name": "Fetch Events",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [930, 100]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "=https://cloud.tal.ahmed-rezk.com/remote.php/dav/calendars/admin/personal/{{ Date.now() }}.ics",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "text/calendar",
        "body": "={{ 'BEGIN:VCALENDAR\\r\\nVERSION:2.0\\r\\nPRODID:-//n8n//Nextcloud//EN\\r\\nBEGIN:VEVENT\\r\\nUID:n8n-event-' + Date.now() + '\\r\\nDTSTAMP:' + $now.toFormat(\"yyyyMMdd'T'HHmmss'Z'\") + '\\r\\nSUMMARY:' + $('Set Config').first().json.body.title + '\\r\\nSTATUS:CONFIRMED\\r\\nBEGIN:VALARM\\r\\nACTION:DISPLAY\\r\\nDESCRIPTION:Reminder\\r\\nTRIGGER:-PT15M\\r\\nEND:VALARM\\r\\nEND:VEVENT\\r\\nEND:VCALENDAR' }}",
        "options": {}
      },
      "id": "create-event",
      "name": "Create Event",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [930, 300],
      "credentials": { "httpBasicAuth": { "id": "YOUR_CREDENTIAL_ID", "name": "Nextcloud API" } },
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const body = $('Set Config').first().json.body;\nreturn [{ json: { success: true, message: 'Event created!', event: { title: body.title, uid: 'n8n-event-' + Date.now() } } }];"
      },
      "id": "format-create",
      "name": "Format Create",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1150, 300]
    },
    {
      "parameters": {
        "method": "DELETE",
        "url": "=https://cloud.tal.ahmed-rezk.com/remote.php/dav/calendars/admin/personal/{{ $('Set Config').first().json.body.eventUid }}.ics",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "options": {}
      },
      "id": "delete-event",
      "name": "Delete Event",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [930, 500],
      "credentials": { "httpBasicAuth": { "id": "YOUR_CREDENTIAL_ID", "name": "Nextcloud API" } },
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { success: true, message: 'Event deleted!', eventUid: $('Set Config').first().json.body.eventUid } }];"
      },
      "id": "format-delete",
      "name": "Format Delete",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1150, 500]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { success: false, message: 'Invalid action. Use: fetch, create, delete' } }];"
      },
      "id": "format-error",
      "name": "Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [930, 700]
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Set Config", "type": "main", "index": 0 }]] },
    "Set Config": { "main": [[{ "node": "Switch Action", "type": "main", "index": 0 }]] },
    "Switch Action": { "main": [[{ "node": "Fetch Events", "type": "main", "index": 0 }], [{ "node": "Create Event", "type": "main", "index": 0 }], [{ "node": "Delete Event", "type": "main", "index": 0 }], [{ "node": "Error", "type": "main", "index": 0 }]] },
    "Create Event": { "main": [[{ "node": "Format Create", "type": "main", "index": 0 }]] },
    "Delete Event": { "main": [[{ "node": "Format Delete", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "staticData": null,
  "tags": [],
  "triggerCount": 1
}
