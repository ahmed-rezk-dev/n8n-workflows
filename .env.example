# PostgreSQL Configuration
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=n8n

# n8n Basic Auth (login credentials)
N8N_USER=admin
N8N_PASSWORD=change_me_to_a_strong_password

# Nextcloud Configuration
NEXTCLOUD_URL=https://your-nextcloud-domain.com
NEXTCLOUD_USER=your_username
NEXTCLOUD_APP_PASSWORD=your_app_password

# n8n Configuration
N8N_HOST=localhost  # Change to your domain or IP address
TZ=America/New_York  # Change to your timezone
